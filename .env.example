# JWT Secret - used for signing authentication tokens
JWT_SECRET=

# PostgreSQL (used by docker-compose)
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# Database URL (PostgreSQL via Docker)
# Format: postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@localhost:<POSTGRES_PORT>/<POSTGRES_DB>
DATABASE_URL=

# Next.js public URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
